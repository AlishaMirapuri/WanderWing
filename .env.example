# Database
DATABASE_URL=sqlite:///./data/wanderwing.db
# For PostgreSQL: postgresql://user:password@localhost:5432/wanderwing

# LLM Provider Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Settings
LLM_MODEL=gpt-4-turbo-preview  # or claude-3-sonnet-20240229
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Frontend Configuration
FRONTEND_PORT=8501

# Application Settings
ENABLE_EXPERIMENTS=true
EXPERIMENT_CONFIG_PATH=./data/experiments.json
LOG_LEVEL=INFO
LOG_FORMAT=json  # Options: json, text

# Security
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=["http://localhost:8501"]

# Feature Flags
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=false
RATE_LIMIT_PER_MINUTE=60

# Cost Control
MAX_LLM_CALLS_PER_USER_PER_HOUR=50
ALERT_COST_THRESHOLD_USD=10.0

# Matching Configuration
MAX_MATCHES_PER_TRIP=10
MATCHING_FREQUENCY_HOURS=1
LLM_SIMILARITY_WEIGHT=0.6
RULE_BASED_WEIGHT=0.4
